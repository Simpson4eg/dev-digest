# Base URL of the running DevDigest Fastify API (@devdigest/api).
DEVDIGEST_API_URL=http://localhost:3001

# Bounded wait for run_agent_on_pr before it falls back to {status:'running'}.
# MUST be shorter than your MCP client's own tool-call timeout (often ~60s),
# otherwise the client aborts the call before the graceful fallback returns.
DEVDIGEST_RUN_TIMEOUT_MS=50000

# How often run_agent_on_pr polls the run status while waiting.
DEVDIGEST_POLL_INTERVAL_MS=2000

# Per-request HTTP timeout for a single API call.
DEVDIGEST_REQUEST_TIMEOUT_MS=15000

# Optional bearer token, forwarded as `Authorization: Bearer <token>`.
# Not needed in the current local no-auth MVP; a seam for when real auth lands.
# DEVDIGEST_API_TOKEN=
